@page "/myorders"
@implements IAsyncDisposable
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<BookstoreDb> DbFactory
@rendermode InteractiveServer

<PageTitle>Bookstore - My Orders</PageTitle>

@if (orders is null)
{
    <p>Loading...</p>
}
else if (!orders.Any())
{
    <p>No orders placed yet.</p>
}
else
{
    @foreach (var order in orders)
    {
        <div class="border-bottom py-3">
            <h5>@order.OrderDate.ToString("MMMM d, yyyy")</h5>
            @foreach (var item in order.OrderItems)
            {
                <div class="d-flex justify-content-between">
                    <span><strong>@item.Book.Title (@item.Quantity):</strong></span>
                    <span>$@item.GetTotal().ToString("F2")</span>
                </div>
            }
            <div class="mt-1">
                <a>Total (@order.OrderItems.Count) : $@order.GetTotal().ToString("F2")</a>
            </div>
        </div>
    }
}

@code {
    private BookstoreDb context { get; set; } = default!;
    private List<Order> orders { get; set; } = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    protected override async Task OnInitializedAsync()
    {
        orders = await context.Orders
            .Include(o => o.OrderItems)
            .ThenInclude(i => i.Book)
            .OrderByDescending(o => o.OrderDate)
            .ToListAsync();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
