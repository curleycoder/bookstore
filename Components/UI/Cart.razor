@inject OrderState OrderState
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

@* Cart icon trigger *@
<span role="button" class="position-relative fs-4 fw-bold text-white" @onclick="ToggleCart">
    <i class="bi bi-cart"></i>
    @if (OrderItems.Any())
    {
        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
              style="font-size: 0.8rem;">
            @OrderItems.Count()
        </span>
    }
</span>

@* Backdrop *@
@if (isOpen)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="background:rgba(0,0,0,0.4); z-index:1040;"
         @onclick="ToggleCart"></div>
}

@* Sidebar panel *@
<div class="position-fixed top-0 end-0 h-100 bg-white shadow d-flex flex-column"
     style="width:320px; z-index:1045; transform:@(isOpen ? "translateX(0)" : "translateX(100%)"); transition:transform 0.3s ease;">
    <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
        <h5 class="mb-0">Your order</h5>
        <button class="btn-close" @onclick="ToggleCart"></button>
    </div>
    <div class="p-3 flex-grow-1 overflow-auto">
        @if (OrderItems.Any())
        {
            @foreach (var item in OrderItems)
            {
                <CartItem
                    item="@item"
                    OnIncrement="() => Increment(item)"
                    OnDecrement="() => Decrement(item)"
                    OnRemove="() => Remove(item)" />
            }
        }
        else
        {
            <p>There are no items in the cart</p>
        }
    </div>
    <div class="p-3 border-top">
        <button class="btn btn-warning w-100" @onclick="Checkout">Proceed to checkout</button>
    </div>
</div>

@code {
    private List<OrderItem> OrderItems => OrderState.Order.OrderItems;
    private bool isOpen = false;

    protected override void OnInitialized()
    {
        OrderState.OnChange += StateHasChanged;
    }

    private void ToggleCart() => isOpen = !isOpen;

    private void Checkout()
    {
        isOpen = false;
        NavigationManager.NavigateTo("checkout");
    }

    public void Increment(OrderItem item)
    {
        if (item.Quantity < 5) item.Quantity++;
    }

    public void Decrement(OrderItem item)
    {
        if (item.Quantity > 1) item.Quantity--;
    }

    public void Remove(OrderItem item)
    {
        OrderState.RemoveItem(item);
    }
}
